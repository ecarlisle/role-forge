{
  "name": "roleforge",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others \"bun run dev:server\" \"bun run dev:frontend\"",
    "dev:server": "bun run --watch packages/server/src/index.ts",
    "dev:frontend": "vite packages/frontend",
    "build": "vite build packages/frontend",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "bun test packages/server",
    "lint": "biome lint packages/",
    "format": "biome format --write packages/",
    "format:check": "biome format packages/",
    "check": "biome check packages/",
    "check:write": "biome check --write packages/",
    "seed": "bun run packages/server/src/seed.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "bun-types": "^1.3.14",
    "concurrently": "^9.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  }
}
