{
  "name": "roleforge",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others \"bun run dev:server\" \"bun run dev:frontend\"",
    "dev:server": "bun run --watch packages/server/src/index.ts",
    "dev:frontend": "vite packages/frontend",
    "build": "vite build packages/frontend",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "bun test packages/server",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}' 'packages/*/tests/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,css}' 'packages/*/tests/**/*.{ts,tsx}'",
    "seed": "bun run packages/server/src/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "bun-types": "^1.3.14",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  }
}
